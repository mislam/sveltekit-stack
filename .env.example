# Database — local dev uses Neon HTTP proxy (same driver as production)
# https://neon.com/guides/local-development-with-neon
DATABASE_URL=postgresql://postgres:postgres@db.localtest.me:5432/main

# Better Auth secret key for encryption and hashing
# Generate with: bun auth:secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173 # Base URL of your app

# Google OAuth client for sign-in with Better Auth
# https://www.better-auth.com/docs/authentication/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
